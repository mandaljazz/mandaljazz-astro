---
import { Image } from "astro:assets";
import "mapbox-gl/dist/mapbox-gl.css";
import mapPlaceholder from "../images/map-placeholder.png";
import "../styles/mapbox-overrides.css";
import Link from "./Link.astro";
---

<div class="venue-map flex flex-col">
  <div class="relative h-72 w-full sm:h-96 md:h-[480px]">
    <Image
      id="venue-map-placeholder"
      src={mapPlaceholder}
      alt=""
      aria-hidden="true"
      widths={[640, 960, 1280, 2038]}
      sizes="100vw"
      class="absolute inset-0 z-10 h-full w-full object-cover animate-pulse blur-sm"
    />
    <div id="map" class="h-full w-full"></div>
  </div>
  <div class="mt-3 flex flex-row justify-between">
    <address class="not-italic">
      <Link
        href="https://goo.gl/maps/faFwNkmTR28gCYRA6"
        external
        title="Keiser Nicolaus gate 8–12, 4515 Mandal"
        class="text-sm"
      >
        Keiser Nicolaus gate 8–12,<br />4515 Mandal
      </Link>
    </address>
    <button
      type="button"
      class="link mt-1 h-fit whitespace-nowrap text-left text-sm"
      id="venue-map-reset-view"
    >
      Se kartet ovenfra
    </button>
  </div>
</div>

<script>
  import mapboxgl, { type LngLatLike } from "mapbox-gl";

  const mapboxToken = import.meta.env.PUBLIC_MAPBOX_ACCESS_TOKEN;
  if (!mapboxToken) {
    throw new Error(
      "PUBLIC_MAPBOX_ACCESS_TOKEN is not set. Add it to .env — see .env.example.",
    );
  }
  mapboxgl.accessToken = mapboxToken;

  const venues = [
    {
      id: "teltet",
      directionsLink: "https://goo.gl/maps/tyHoBufCjgKrQuVWA",
      name: "Teltet",
      supportText: "på Kulturfabrikken",
      coordinates: [7.457609, 58.024953],
      isBig: true,
    },
    {
      id: "bakgården",
      directionsLink: "https://goo.gl/maps/tyHoBufCjgKrQuVWA",
      name: "Bakgården",
      supportText: "på Kulturfabrikken",
      coordinates: [7.457936, 58.025016],
    },
    {
      id: "buen",
      directionsLink: "https://goo.gl/maps/DFWhAkxsG79Z6XsSA",
      name: "Buen",
      supportText: "Storsalen, Elvesalen, foajéen",
      coordinates: [7.456102489810863, 58.025413017347816],
    },
    {
      id: "dynamitten",
      directionsLink: "https://maps.app.goo.gl/6Xg1GqjQRNGNcQSz9",
      name: "Dynamitten",
      coordinates: [7.457231669041564, 58.02783419221465],
    },
    {
      id: "piren",
      directionsLink: "https://goo.gl/maps/wUtGQW5PBwdmxqvW8",
      name: "Piren Kulturrom",
      coordinates: [7.45642627188327, 58.02126823756139],
    },
    {
      id: "hestetroa",
      directionsLink: "https://goo.gl/maps/7jcZQyep46oVotuA6",
      name: "Hestetroa",
      coordinates: [7.455256960080562, 58.027854579180655],
    },
    {
      id: "gierts-karis-plass",
      directionsLink: "https://maps.app.goo.gl/TpzB1xaWbCipA6Rc6",
      name: "Gierts Karis Plass",
      coordinates: [7.4551365365068, 58.02751134416798],
    },
    {
      id: "torvet",
      directionsLink: "https://maps.app.goo.gl/CEc33VpS5EPt52kn6",
      name: "Torvet",
      coordinates: [7.453459563180011, 58.0274667812675],
    },
    {
      id: "rokta-mandal-tannklinikk",
      directionsLink: "https://maps.app.goo.gl/cEKKX4fmqcEyWUU4A",
      name: "Røkta / Mandal Tannklinikk",
      coordinates: [7.448687356550957, 58.024104342961905],
    },
    {
      id: "landoy-broed-pizza",
      directionsLink: "https://maps.app.goo.gl/Ag64AGgZgctP8i4PA",
      name: "Landøy Brød & Pizza",
      coordinates: [7.449646944178234, 58.02513693285713],
    },
    {
      id: "kommunestyresalen",
      directionsLink: "https://maps.app.goo.gl/49ePj9cFANamUevM9",
      name: "Kommunestyresalen",
      coordinates: [7.450029001849526, 58.02628169071628],
    },
  ];

  const centerDesktop: LngLatLike = [7.45479, 58.02391];
  /** Slightly south-east of desktop (narrower viewports need a nudge). */
  const centerMobile: LngLatLike = [7.4545, 58.02347];

  const isMobileViewport = window.matchMedia("(max-width: 639px)").matches;
  const center = isMobileViewport ? centerMobile : centerDesktop;

  const navigationControl = new mapboxgl.NavigationControl();
  const fullscreenControl = new mapboxgl.FullscreenControl();
  const geolocateControl = new mapboxgl.GeolocateControl();

  const initialZoom = 12.45;
  const introZoomDesktop = 15.15;
  const introZoomMobile = 14.7;
  const introZoom = isMobileViewport ? introZoomMobile : introZoomDesktop;
  const introPitch = 68;
  const introBearingDesktop = -20;
  const introBearingMobile = -24;
  const introBearing = isMobileViewport
    ? introBearingMobile
    : introBearingDesktop;

  const map = new mapboxgl.Map({
    container: "map",
    style: "mapbox://styles/mapbox/streets-v12",
    center,
    zoom: initialZoom,
    pitch: 0,
    bearing: 0,
  });

  map.once("load", () => {
    const placeholder = document.getElementById("venue-map-placeholder");
    placeholder?.classList.add("opacity-0");
    placeholder?.classList.remove("animate-pulse");
    placeholder?.remove();

    map.flyTo({
      center,
      zoom: introZoom,
      pitch: introPitch,
      duration: 2800,
      curve: 1.35,
      essential: true,
      bearing: introBearing,
    });
  });

  map.addControl(navigationControl, "top-left");
  map.addControl(geolocateControl, "top-left");
  map.addControl(fullscreenControl, "top-right");

  map.on("style.load", () => {
    // Insert the layer beneath any symbol layer.
    const layers = map.getStyle().layers;
    const labelLayerId = layers.find(
      ({ type, layout }) => type === "symbol" && layout["text-field"],
    ).id;

    // The 'building' layer in the Mapbox Streets
    // vector tileset contains building height data
    // from OpenStreetMap.
    map.addLayer(
      {
        id: "add-3d-buildings",
        source: "composite",
        "source-layer": "building",
        filter: ["==", "extrude", "true"],
        type: "fill-extrusion",
        minzoom: 14,
        paint: {
          "fill-extrusion-color": "#fff",
          "fill-extrusion-height": { type: "identity", property: "height" },
          "fill-extrusion-base": { type: "identity", property: "min_height" },
          "fill-extrusion-opacity": 0.6,
        },
      },
      labelLayerId,
    );

    // Define a source before using it to create a new layer
    map.addSource("venues-source", {
      type: "geojson",
      data: {
        type: "FeatureCollection",
        features: venues.map(
          ({ name, supportText, directionsLink, coordinates, isBig }) => ({
            type: "Feature",
            properties: {
              name: name,
              supportText: supportText,
              directionsLink: directionsLink,
              isBig: isBig,
            },
            geometry: {
              type: "Point",
              coordinates: coordinates,
            },
          }),
        ),
      },
    });

    const venueRadiusSm = 9;
    const venueRadiusLg = 20;
    const venueStrokeSm = 2;
    const venueStrokeLg = 3.5;

    map.addLayer({
      type: "circle",
      id: "venues-layer",
      source: "venues-source",
      paint: {
        "circle-radius": [
          "case",
          ["==", ["get", "isBig"], true],
          venueRadiusLg,
          venueRadiusSm,
        ],
        "circle-color": "#d14d39",
        "circle-stroke-color": "#efc54c",
        "circle-stroke-width": [
          "case",
          ["==", ["get", "isBig"], true],
          venueStrokeLg,
          venueStrokeSm,
        ],
        "circle-opacity": 1,
      },
    });
  });

  // Center the map on the coordinates of any clicked venues-layer from the 'venues-layer' layer.
  map.on("click", "venues-layer", ({ features, lngLat }) => {
    const feature = features?.[0];
    if (!feature?.geometry || feature.geometry.type !== "Point") return;

    // Copy coordinates array.
    const coordinates = [...feature.geometry.coordinates];
    const { name, directionsLink, supportText } = feature.properties ?? {};

    // Ensure that if the map is zoomed out such that multiple
    // copies of the feature are visible, the popup appears
    // over the copy being pointed to.
    while (Math.abs(lngLat.lng - coordinates[0]) > 180) {
      coordinates[0] += lngLat.lng > coordinates[0] ? 360 : -360;
    }

    new mapboxgl.Popup({ offset: 25 })
      .setHTML(
        `<div class="space-y-2">
          <div>
            <h3 class="text-lg">${name}</h3>
            ${supportText ? `<div>${supportText}</div>` : ""}
          </div>
          ${
            directionsLink &&
            `<div><a class="link font-display" href=${directionsLink} target="_blank" rel="noopener noreferrer">Åpne i Google Maps</a></div>`
          }
        </div>
        `,
      )
      .setLngLat([coordinates[0], coordinates[1]])
      .addTo(map);

    map.flyTo({
      center: [lngLat.lng, lngLat.lat],
      speed: 0.5,
      curve: 2,
    });
  });

  // Change the cursor to a pointer when the it enters a feature in the 'venues-layer' layer.
  map.on("mouseenter", "venues-layer", () => {
    map.getCanvas().style.cursor = "pointer";
  });

  // Change it back to a pointer when it leaves.
  map.on("mouseleave", "venues-layer", () => {
    map.getCanvas().style.cursor = "";
  });

  document
    .getElementById("venue-map-reset-view")
    ?.addEventListener("click", () => {
      map.easeTo({
        zoom: isMobileViewport ? 13 : 14,
        center: isMobileViewport ? centerMobile : centerDesktop,
        pitch: 0,
        bearing: 0,
        duration: 750,
        essential: true,
      });
    });
</script>
