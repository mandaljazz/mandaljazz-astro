---
// Unified Tag component
import { Icon } from "astro-icon";

export interface Props {
  className?: string;
  size?: "small" | "medium";
  variant:
    | "free"
    | "barnekonsert"
    | "morgensolo"
    | "soldout"
    | "bestillingsverk"
    | "fewtickets"
    | "moved";
}

const { className, size = "medium", variant } = Astro.props;

const iconSize = size === "small" ? 16 : 24;

// Variant configurations
const variants = {
  free: {
    bgColor: "bg-pink",
    textColor: "text-black",
    icon: "balloon-outline",
    label: "Gratis",
  },
  barnekonsert: {
    bgColor: "bg-light-green",
    textColor: "text-black",
    icon: "people-outline",
    label: "Barnekonsert",
  },
  morgensolo: {
    bgColor: "bg-yellow",
    textColor: "",
    icon: "sunny-outline",
    label: "Morgensolo",
  },
  soldout: {
    bgColor: "bg-dark-red",
    textColor: "text-white",
    icon: null, // No icon for sold out
    label: "Utsolgt!",
  },
  bestillingsverk: {
    bgColor: "bg-green",
    textColor: "text-white",
    icon: "color-palette-outline",
    label: "Bestillingsverk",
  },
  fewtickets: {
    bgColor: "bg-red",
    textColor: "text-white",
    icon: "flash-outline",
    label: "Få billetter",
  },
  moved: {
    bgColor: "bg-yellow",
    textColor: "text-black",
    icon: "swap-horizontal-outline",
    label: "Flyttet pga. VM",
  },
};

const { bgColor, textColor, icon, label } = variants[variant];
---

<div
  class:list={[
    `${bgColor} ${textColor} flex w-fit flex-row items-center rounded-md whitespace-nowrap`,
    className,
    size === "small" && "gap-1 rounded px-1 py-1 text-xs",
    size === "medium" && "gap-2 rounded-md px-2.5 py-1.5",
  ]}
>
  {icon && <Icon pack="ion" name={icon} size={iconSize} />}
  {label}
</div>
