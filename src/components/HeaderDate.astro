---
export interface Props {
  class?: string;
  id?: string;
}

const { class: extraClasses, id } = Astro.props;
---

<div
  id={id}
  class={`relative header-date h-fit flex gap-2 opacity-0 transition-[opacity,transform] duration-300 ${extraClasses || ""}`}
>
  <div
    class="bg-red whitespace-nowrap rounded-lg px-3 py-1 text-xs font-medium text-black"
  >
    9.–11. juli 2026
  </div>
</div>
