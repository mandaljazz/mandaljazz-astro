---
import classNames from "classnames";
import { formatDate } from "../utils/date";
import ImageWithBlurredBackground from "./ImageWithBlurredBackground.astro";

export interface Props {
  title: string;
  ingress?: string;
  href: string;
  image: string;
  className?: string;
  createdAt: Date;
  updatedAt?: Date;
}

const { href, title, ingress, image, className, createdAt, updatedAt } =
  Astro.props;
---

<li class={classNames(`group rounded-xl w-full space-y-4`, className)}>
  <a href={href} class="block w-full transition-transform group-hover:rotate-2">
    <ImageWithBlurredBackground
      src={image}
      alt={title}
      className="h-96 rounded-xl sm:h-72"
    />
  </a>
  <a href={href} class="block w-full">
    <h2 class={classNames("font-medium w-full text-xl")}>
      {title}
    </h2>
    {
      ingress && (
        <div class="w-full text-base transition-transform">
          <p>{ingress}</p>
        </div>
      )
    }
    <div class="flex w-full flex-row gap-1 text-black/60">
      <time datetime={createdAt.toISOString()}>{formatDate(createdAt)}</time>
    </div>
  </a>
</li>
