---
import { getCollection } from "astro:content";
import partition from "lodash/partition";

import { Image } from "astro:assets";
import classNames from "classnames";
import ArtistCard from "../components/ArtistCard.astro";
import BuyTicketsButton from "../components/BuyTicketsButton.astro";
import Spotify from "../components/Spotify.astro";
import Layout from "../layouts/Layout.astro";
import { getArtistUrl } from "../utils/artist";

const artistEntries = await getCollection("artist");
const artistList = artistEntries.map((entry) => ({
  slug: entry.slug,
  frontmatter: entry.data,
}));

// Filter to only show current year artists (2026)
const currentYear = "2026";
const currentYearArtistsNotHidden = artistList.filter((artist) => {
  // Check if slug starts with current year (e.g., "2026/pumpegris")
  return (
    !artist.frontmatter.hideFromArtistList &&
    (artist.slug.startsWith(`${currentYear}/`) || artist.slug === currentYear)
  );
});

const [upcomingArtists, pastArtists] = partition(
  currentYearArtistsNotHidden,
  (artist) => {
    const {
      frontmatter: { concertStartAt },
    } = artist;

    return concertStartAt && new Date(concertStartAt) > new Date();
  },
);

const byOrder = (a, b) => {
  const aOrder = Number(a.frontmatter.order) || Number.NEGATIVE_INFINITY;
  const bOrder = Number(b.frontmatter.order) || Number.NEGATIVE_INFINITY;
  return bOrder - aOrder;
};
---

<Layout title="Mandaljazz 2026" description="Jazzfestivalen i Mandal">
  <main class="space-y-24">
    <div
      class="bg-blue relative flex h-[60vh] max-h-[560px] min-h-[420px] w-full flex-col gap-8 overflow-hidden sm:gap-12"
    >
      <div class="absolute inset-0 top-8 sm:top-16">
        <video
          autoplay
          playsinline
          muted
          class="h-full w-full object-cover"
          loop
          preload="metadata"
          poster="/video/mandaljazz-header-poster.jpg"
        >
          <source
            src="/video/mandaljazz-header-2026-720-30fps.webm"
            type="video/webm"
          />
          <source
            src="/video/mandaljazz-header-2026-720-30fps.mp4"
            type="video/mp4"
          />
          Beklager, her skulle det egentlig vært en video, men nettleseren din støtter
          ikke innebygde videoer :(
        </video>
      </div>
      <div class="relative z-10 flex min-h-full w-full flex-col gap-8">
        <div class="mx-auto flex w-full max-w-5xl flex-col items-center gap-8">
          <div
            class="relative flex w-full flex-col items-center gap-4 pt-32 md:pt-48 lg:mx-auto lg:w-fit"
          >
            <div class="flex flex-col">
              <div class="relative flex w-full">
                <h1
                  class="z-10 flex flex-col items-end font-league-spartan leading-snug text-black"
                >
                  <span
                    class="bg-dark-blue block rounded-full px-6 md:px-12 pt-4 md:pt-8 pb-2 md:pb-6 text-center text-4xl text-beige sm:text-7xl"
                    >9.–11. juli 2026</span
                  >
                </h1>
                <!-- New date badge -->
                <div
                  class="absolute -right-10 -top-6 z-10 sm:-right-10 sm:-top-8"
                >
                  <div
                    class="delay-2500 bg-blue rotate-12 transform rounded-full px-3 py-1 md:px-5 md:py-3 text-beige"
                  >
                    <span class="uppercase font-display leading-3">Ny dato</span
                    >
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="relative space-y-24 pb-24">
      <div
        class="mx-auto max-w-5xl space-y-4 px-4 sm:space-y-8 sm:px-6 md:px-8 lg:px-16 xl:px-32"
      >
        <ul
          role="list"
          class="grid grid-cols-1 gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3"
        >
          {
            [
              ...upcomingArtists.sort(byOrder),
              ...pastArtists.sort(byOrder),
            ].map((artist, index) => {
              const {
                slug,
                frontmatter: {
                  title,
                  shortTitle,
                  tagline,
                  isMorgensolo,
                  isBestillingsverk,
                  isBarnekonsert,
                  isFree,
                  image,
                  cancelled,
                  soldOut,
                  fewTickets,
                },
              } = artist;

              return (
                <ArtistCard
                  className={classNames({
                    "lg:col-span-2 lg:row-span-2 lg:h-[628px]":
                      index === 0 || index === 9,
                    "lg:col-span-2 lg:col-start-2 lg:row-span-2 lg:h-[628px]":
                      index === 4 || index === 16,
                  })}
                  href={getArtistUrl(slug)}
                  title={shortTitle || title}
                  tagline={tagline}
                  slug={slug}
                  image={image}
                  isMorgensolo={isMorgensolo}
                  isBestillingsverk={isBestillingsverk}
                  isBarnekonsert={isBarnekonsert}
                  isFree={isFree}
                  cancelled={cancelled}
                  soldOut={soldOut}
                  fewTickets={fewTickets}
                />
              );
            })
          }
        </ul>
      </div>
      <Spotify src="https://open.spotify.com/playlist/08T1vf3NqWTr99yVF8ZKWv" />
      <BuyTicketsButton class="mx-auto w-fit" />
    </div>
  </main>
</Layout>
